generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String?
  email             String   @unique
  password          String
  role              String   @default("USER")
  avatar            String?
  bio               String?
  phone             String?
  location          String?
  skills            String?
  experience        String?
  education         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  teamsCreated      Team[]               @relation("TeamCreator")
  teamMemberships   TeamMember[]
  teamMessages      TeamMessage[]
  hackathonJoined   HackathonParticipant[]
  hackathonsCreated Hackathon[]
  interviews        Interview[]
  jobs              Job[]
  applications      Application[]
  testAttempts      TestAttempt[]
  results           Result[]
  certificates      Certificate[]
  wallet            Wallet?
  activities        Activity[]
  chatHistories     ChatHistory[]
  aiChatbots        AIChatbot[]
  mockInterviews    MockInterview[]
  selfEvaluations   SelfEvaluation[]
  versantTests      VersantTest[]
  progressMetrics   ProgressMetric[]

  @@index([email])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  hackathonId String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hackathon   Hackathon?   @relation(fields: [hackathonId], references: [id])
  creator     User         @relation("TeamCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members     TeamMember[]
  messages    TeamMessage[]

  @@index([createdBy])
  @@index([hackathonId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model TeamMessage {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([userId])
}

model Hackathon {
  id          String   @id @default(cuid())
  title       String
  description String?
  image       String?
  startDate   DateTime?
  endDate     DateTime?
  prizePool   String?
  status      String   @default("UPCOMING")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     User                      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  teams       Team[]
  participants HackathonParticipant[]

  @@index([createdBy])
  @@index([status])
}

model HackathonParticipant {
  id          String   @id @default(cuid())
  hackathonId String
  userId      String
  joinedAt    DateTime @default(now())

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, userId])
  @@index([hackathonId])
  @@index([userId])
}

model Interview {
  id          String   @id @default(cuid())
  userId      String
  type        String
  duration    Int?
  feedback    String?
  score       Float?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  description String?
  location    String?
  salary      String?
  postedBy    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  postedByUser User          @relation(fields: [postedBy], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([postedBy])
}

model Application {
  id        String   @id @default(cuid())
  jobId     String
  userId    String
  status    String   @default("PENDING")
  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
}

model Test {
  id              String   @id @default(cuid())
  title           String
  description     String?
  duration        Int?
  totalQuestions  Int?
  difficulty      String   @default("MEDIUM")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  questions       Question[]
  attempts        TestAttempt[]
  results         Result[]

  @@index([difficulty])
}

model Question {
  id            String   @id @default(cuid())
  testId        String
  question      String
  type          String   @default("MCQ")
  options       Json?
  correctAnswer String?
  marks         Int      @default(1)
  explanation   String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  test          Test     @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
}

model TestAttempt {
  id        String   @id @default(cuid())
  testId    String
  userId    String
  startedAt DateTime @default(now())
  endedAt   DateTime?
  status    String   @default("IN_PROGRESS")

  test      Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([testId, userId])
  @@index([testId])
  @@index([userId])
}

model Result {
  id          String   @id @default(cuid())
  testId      String
  userId      String
  score       Int
  totalScore  Int?
  accuracy    Float?
  duration    Int?
  status      String   @default("COMPLETED")
  completedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@index([userId])
}

model Certificate {
  id              String   @id @default(cuid())
  userId          String
  title           String
  issuedBy        String?
  certificateId   String?
  certificateUrl  String?
  description     String?
  issuedAt        DateTime @default(now())
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String
  description String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ChatHistory {
  id              String   @id @default(cuid())
  userId          String
  conversationId  String   @default(cuid())
  botType         String   @default("CODING")
  messagesData    String   @default("[]")
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
}
model AIChatbot {
  id        String        @id @default(cuid())
  userId    String
  type      String        @default("CODE")
  title     String        @default("New Chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id         String    @id @default(cuid())
  chatbotId  String
  role       String    @default("USER")
  content    String
  timestamp  DateTime  @default(now())
  feedback   String?

  chatbot    AIChatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
}

model MockInterview {
  id          String    @id @default(cuid())
  userId      String
  jobRole     String
  difficulty  String    @default("MEDIUM")
  status      String    @default("PENDING")
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int?
  score       Float?
  feedback    String?
  videoUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobRole])
}

model SelfEvaluation {
  id          String    @id @default(cuid())
  userId      String
  jobRole     String
  mode        String    @default("ASSESSMENT")
  questions   String    @default("[]")
  answers     String    @default("[]")
  feedback    String?
  score       Float?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VersantTest {
  id               String    @id @default(cuid())
  userId           String
  testType         String
  duration         Int?
  score            Float?
  proficiencyLevel String?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([testType])
}

model ProgressMetric {
  id        String   @id @default(cuid())
  userId    String
  metric    String
  value     Float    @default(0)
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, metric])
  @@index([userId])
}
